{
  "name": "@alhajiry/playwright-testrail-reporter",
  "author": "alhajiry",
  "homepage": "https://github.com/alhajiry/playwright-testrail-reporter",
  "description": "Fork of @bun913/playwright-testrail-reporter with support for multiple TestRail case IDs per test title.",
  "private": false,
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.es.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "format": "biome format --write ./src",
    "test": "vitest ./test --reporter=verbose --coverage",
    "test:ci": "vitest run ./test --silent --coverage --reporter=verbose"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.13.10",
    "@vitest/coverage-v8": "^4.1.4",
    "typescript": "~5.7.2",
    "vite": "^6.2.0",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "@playwright/test": "^1.51.1",
    "axios": "^1.8.3"
  }
}
